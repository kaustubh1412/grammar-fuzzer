int main() {
    unsigned int *h_in, *h_out;
    unsigned int *d_in, *d_out;
    size_t size = N * sizeof(unsigned int);

    // Allocate Host Memory
    h_in = (unsigned int *)malloc(size);
    h_out = (unsigned int *)malloc(size);

    // Initialize Host Data
    for (int i = 0; i < N; i++) {
